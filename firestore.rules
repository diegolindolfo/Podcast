rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: pushSubscriptions
    // Document ID: {subscriptionId}
    // Fields:
    //   - endpoint: string (required)
    //   - keys: map (required)
    //     - p256dh: string
    //     - auth: string
    //   - podcasts: list of strings (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSubscription() {
      let data = request.resource.data;
      return data.keys().hasAll(['endpoint', 'keys', 'podcasts']) &&
             data.endpoint is string &&
             data.keys is map &&
             data.keys.keys().hasAll(['p256dh', 'auth']) &&
             data.keys.p256dh is string &&
             data.keys.auth is string &&
             data.podcasts is list;
    }

    match /pushSubscriptions/{subscriptionId} {
      // Allow any authenticated user (including anonymous) to read subscriptions.
      allow read: if isAuthenticated();

      // Allow authenticated users to create, update, or delete their subscription.
      allow create, update: if isAuthenticated() && isValidSubscription();
      allow delete: if isAuthenticated();
    }
  }
}
